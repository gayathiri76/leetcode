class Solution {
    public int singleNumber(int[] nums) {
        int ones = 0, twos = 0;
        
        for (int num : nums) {
            // 'ones' holds bits that appeared once
            ones = (ones ^ num) & ~twos;
            
            // 'twos' holds bits that appeared twice
            twos = (twos ^ num) & ~ones;
        }
        
        return ones;
    }
}
