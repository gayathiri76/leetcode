import java.util.*;

class Solution {
    public List<List<String>> solveNQueens(int n) {
        List<List<String>> results = new ArrayList<>();
        char[][] board = new char[n][n];
        
        // Initialize board with dots
        for (int i = 0; i < n; i++) {
            Arrays.fill(board[i], '.');
        }

        // Sets to keep track of restricted paths
        Set<Integer> cols = new HashSet<>();
        Set<Integer> posDiag = new HashSet<>(); // (r + c)
        Set<Integer> negDiag = new HashSet<>(); // (r - c)

        backtrack(0, n, board, results, cols, posDiag, negDiag);
        return results;
    }

    private void backtrack(int r, int n, char[][] board, List<List<String>> results,
                           Set<Integer> cols, Set<Integer> posDiag, Set<Integer> negDiag) {
        // Base Case: If we've placed queens in all rows, we found a solution
        if (r == n) {
            results.add(construct(board));
            return;
        }

        for (int c = 0; c < n; c++) {
            // If the current position is under attack, skip it
            if (cols.contains(c) || posDiag.contains(r + c) || negDiag.contains(r - c)) {
                continue;
            }

            // 1. "Choose" - Place the queen
            board[r][c] = 'Q';
            cols.add(c);
            posDiag.add(r + c);
            negDiag.add(r - c);

            // 2. "Explore" - Move to the next row
            backtrack(r + 1, n, board, results, cols, posDiag, negDiag);

            // 3. "Backtrack" - Remove the queen to try other possibilities
            board[r][c] = '.';
            cols.remove(c);
            posDiag.remove(r + c);
            negDiag.remove(r - c);
        }
    }

    private List<String> construct(char[][] board) {
        List<String> path = new ArrayList<>();
        for (int i = 0; i < board.length; i++) {
            path.add(new String(board[i]));
        }
        return path;
    }
}
