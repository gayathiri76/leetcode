import java.util.HashMap;
import java.util.Map;

class Solution {
    public String minWindow(String s, String t) {
        if (s == null || t == null || s.length() < t.length()) return "";

        // Map to store frequencies of characters in t
        Map<Character, Integer> targetCounts = new HashMap<>();
        for (char c : t.toCharArray()) {
            targetCounts.put(c, targetCounts.getOrDefault(c, 0) + 1);
        }

        int left = 0, right = 0;
        int required = targetCounts.size(); // Number of unique characters in t to be matched
        int formed = 0; // Number of unique characters in window that meet required frequency
        
        Map<Character, Integer> windowCounts = new HashMap<>();
        
        // Array to store length of min window, start, and end index
        int[] ans = {-1, 0, 0}; 

        while (right < s.length()) {
            char c = s.charAt(right);
            windowCounts.put(c, windowCounts.getOrDefault(c, 0) + 1);

            // If current character's frequency matches its target frequency, increment 'formed'
            if (targetCounts.containsKey(c) && 
                windowCounts.get(c).intValue() == targetCounts.get(c).intValue()) {
                formed++;
            }

            // Try to contract the window from the left once all characters are present
            while (left <= right && formed == required) {
                c = s.charAt(left);

                // Update the result if this window is smaller than previous best
                if (ans[0] == -1 || (right - left + 1) < ans[0]) {
                    ans[0] = right - left + 1;
                    ans[1] = left;
                    ans[2] = right;
                }

                // Remove the character at 'left' from window and update state
                windowCounts.put(c, windowCounts.get(c) - 1);
                if (targetCounts.containsKey(c) && 
                    windowCounts.get(c).intValue() < targetCounts.get(c).intValue()) {
                    formed--;
                }
                left++;
            }
            right++;
        }

        return ans[0] == -1 ? "" : s.substring(ans[1], ans[2] + 1);
    }
}
