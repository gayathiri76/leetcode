class Solution {
    public int removeDuplicates(int[] nums) {
        // If the array has 2 or fewer elements, it already meets the criteria
        if (nums.length <= 2) {
            return nums.length;
        }

        // Pointer 'k' is the index where we write the next valid element.
        // We start from 2 because the first two elements are always allowed.
        int k = 2;

        for (int i = 2; i < nums.length; i++) {
            // Compare current element with the element 2 positions back in the result part
            if (nums[i] != nums[k - 2]) {
                nums[k] = nums[i];
                k++;
            }
        }

        return k;
    }
}
