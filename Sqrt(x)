class Solution {
    public int mySqrt(int x) {
        // Handle edge cases for 0 and 1
        if (x < 2) return x;

        int left = 2;
        int right = x / 2; // The square root of x (where x > 1) is never more than x/2
        int ans = 1;

        while (left <= right) {
            int mid = left + (right - left) / 2;
            
            // Use division to avoid integer overflow (mid * mid can exceed Integer.MAX_VALUE)
            if (mid <= x / mid) {
                ans = mid;     // mid is a potential candidate
                left = mid + 1; // look for a larger value
            } else {
                right = mid - 1; // mid is too large
            }
        }

        return ans;
    }
}
