import java.util.ArrayList;
import java.util.List;

class Solution {
    public List<List<Integer>> combine(int n, int k) {
        List<List<Integer>> result = new ArrayList<>();
        backtrack(result, new ArrayList<>(), 1, n, k);
        return result;
    }

    private void backtrack(List<List<Integer>> result, List<Integer> current, int start, int n, int k) {
        // Base Case: If the combination is done
        if (current.size() == k) {
            result.add(new ArrayList<>(current));
            return;
        }

        // Optimization: Only iterate if there are enough numbers left to fill k slots
        // i <= n - (k - current.size()) + 1
        for (int i = start; i <= n; i++) {
            // 1. Action: Add the number
            current.add(i);
            
            // 2. Explore: Move to the next number
            backtrack(result, current, i + 1, n, k);
            
            // 3. Backtrack: Remove the number to try the next candidate
            current.remove(current.size() - 1);
        }
    }
}
