public class Solution {
    // Treat n as an unsigned value
    public int reverseBits(int n) {
        int result = 0;
        for (int i = 0; i < 32; i++) {
            // 1. Shift result to the left to make room for the next bit
            result <<= 1;
            
            // 2. Get the last bit of n using bitwise AND (& 1)
            // 3. Add it to result using bitwise OR (|)
            result |= (n & 1);
            
            // 4. Shift n to the right to process the next bit
            n >>= 1;
        }
        return result;
    }
}
