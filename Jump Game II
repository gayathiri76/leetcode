class Solution {
    public int jump(int[] nums) {
        // If the array has 1 element, we are already at the destination
        if (nums.length <= 1) return 0;

        int jumps = 0;
        int currentEnd = 0;
        int farthest = 0;

        // Iterate up to n - 1 (we don't need to jump from the last index)
        for (int i = 0; i < nums.length - 1; i++) {
            // Update the farthest index we can reach from the current index
            farthest = Math.max(farthest, i + nums[i]);

            // If we've reached the end of the range of the current jump
            if (i == currentEnd) {
                jumps++;
                currentEnd = farthest;

                // Optimization: if currentEnd already reaches or passes the last index
                if (currentEnd >= nums.length - 1) break;
            }
        }

        return jumps;
    }
}
