class Solution {
    public int findPeakElement(int[] nums) {
        int left = 0;
        int right = nums.length - 1;

        while (left < right) {
            int mid = left + (right - left) / 2;

            // If the middle element is less than the next one,
            // we are on an upward slope, so a peak must be to the right.
            if (nums[mid] < nums[mid + 1]) {
                left = mid + 1;
            } 
            // If the middle element is greater than the next one,
            // we are on a downward slope, so a peak is either at mid or to the left.
            else {
                right = mid;
            }
        }

        // Left and right will eventually meet at a peak index.
        return left;
    }
}
