import java.util.*;

class Solution {
    public String largestNumber(int[] nums) {
        // 1. Convert integers to strings
        String[] asStrings = new String[nums.length];
        for (int i = 0; i < nums.length; i++) {
            asStrings[i] = String.valueOf(nums[i]);
        }

        // 2. Custom sort based on concatenation
        Arrays.sort(asStrings, (a, b) -> (b + a).compareTo(a + b));

        // 3. Handle the edge case where the largest number is "0"
        if (asStrings[0].equals("0")) {
            return "0";
        }

        // 4. Build the final string
        StringBuilder sb = new StringBuilder();
        for (String s : asStrings) {
            sb.append(s);
        }

        return sb.toString();
    }
}
