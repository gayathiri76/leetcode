import java.util.Stack;

class Solution {
    public int longestValidParentheses(String s) {
        // Stack will store the indices of characters
        Stack<Integer> stack = new Stack<>();
        
        // Push -1 as a base index for calculation 
        // (helps calculate length when the valid string starts from index 0)
        stack.push(-1);
        int maxLength = 0;

        for (int i = 0; i < s.length(); i++) {
            char c = s.charAt(i);

            if (c == '(') {
                // Always push the index of an opening parenthesis
                stack.push(i);
            } else {
                // It's a closing parenthesis ')', pop the last matched index
                stack.pop();

                if (stack.isEmpty()) {
                    // If empty, this ')' is unmatched and becomes the new base
                    stack.push(i);
                } else {
                    // Current length = current index - index of the last unmatched element
                    maxLength = Math.max(maxLength, i - stack.peek());
                }
            }
        }

        return maxLength;
    }
}
