class Solution {
    public int strStr(String haystack, String needle) {
        int hLen = haystack.length();
        int nLen = needle.length();

        // If needle is longer than haystack, it cannot be a substring
        if (nLen > hLen) {
            return -1;
        }

        // Only need to iterate up to the point where the remaining 
        // characters in haystack are at least as long as needle
        for (int i = 0; i <= hLen - nLen; i++) {
            // Check if the substring starting at i matches needle
            if (haystack.substring(i, i + nLen).equals(needle)) {
                return i;
            }
        }

        return -1;
    }
}
