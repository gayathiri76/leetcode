import java.util.*;

class Solution {
    int postorderIndex;
    Map<Integer, Integer> inorderIndexMap;

    public TreeNode buildTree(int[] inorder, int[] postorder) {
        // Start from the last element of postorder
        postorderIndex = postorder.length - 1;
        inorderIndexMap = new HashMap<>();

        // Map values to indices for O(1) lookup in inorder array
        for (int i = 0; i < inorder.length; i++) {
            inorderIndexMap.put(inorder[i], i);
        }

        return helper(postorder, 0, inorder.length - 1);
    }

    private TreeNode helper(int[] postorder, int left, int right) {
        if (left > right) return null;

        // The current root is the element at postorderIndex
        int rootValue = postorder[postorderIndex--];
        TreeNode root = new TreeNode(rootValue);

        // Get the split point from inorder map
        int index = inorderIndexMap.get(rootValue);

        // IMPORTANT: Build the RIGHT subtree first 
        // because postorder is Left-Right-Root (Right is visited before Left when moving backwards)
        root.right = helper(postorder, index + 1, right);
        root.left = helper(postorder, left, index - 1);

        return root;
    }
}
