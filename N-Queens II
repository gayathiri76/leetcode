class Solution {
    private int count = 0;

    public int totalNQueens(int n) {
        // Track columns and both types of diagonals
        boolean[] cols = new boolean[n];
        boolean[] diag = new boolean[2 * n];      // (row + col)
        boolean[] antiDiag = new boolean[2 * n];  // (row - col + n)

        backtrack(0, n, cols, diag, antiDiag);
        return count;
    }

    private void backtrack(int row, int n, boolean[] cols, boolean[] diag, boolean[] antiDiag) {
        // Base case: All queens are placed
        if (row == n) {
            count++;
            return;
        }

        for (int col = 0; col < n; col++) {
            int d1 = row + col;
            int d2 = row - col + n;

            // Check if position is under attack
            if (cols[col] || diag[d1] || antiDiag[d2]) {
                continue;
            }

            // Place queen (mark paths as occupied)
            cols[col] = true;
            diag[d1] = true;
            antiDiag[d2] = true;

            // Move to the next row
            backtrack(row + 1, n, cols, diag, antiDiag);

            // Backtrack (remove queen and unmark paths)
            cols[col] = false;
            diag[d1] = false;
            antiDiag[d2] = false;
        }
    }
}
