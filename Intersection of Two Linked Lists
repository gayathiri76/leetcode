/**
 * Definition for singly-linked list.
 * public class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {
    public ListNode getIntersectionNode(ListNode headA, ListNode headB) {
        if (headA == null || headB == null) return null;

        ListNode a = headA;
        ListNode b = headB;

        // If a and b have different lengths, then they will stop being 
        // null at different times. By switching heads, both pointers 
        // will eventually travel the exact same total distance (LengthA + LengthB).
        while (a != b) {
            // If pointer 'a' reaches the end, reset it to headB
            a = (a == null) ? headB : a.next;
            // If pointer 'b' reaches the end, reset it to headA
            b = (b == null) ? headA : b.next;
        }

        // They will either meet at the intersection node or at null (no intersection)
        return a;
    }
}
