class Solution {
    public List<String> generateParenthesis(int n) {
        List<String> result = new ArrayList<>();
        backtrack(result, "", 0, 0, n);
        return result;
    }

    private void backtrack(List<String> result, String currentString, int open, int close, int max) {
        // Base case: If the string reaches the maximum length (2 * n)
        if (currentString.length() == max * 2) {
            result.add(currentString);
            return;
        }

        // Logic 1: We can always add an opening bracket if we haven't reached 'n'
        if (open < max) {
            backtrack(result, currentString + "(", open + 1, close, max);
        }

        // Logic 2: We can only add a closing bracket if it doesn't exceed the number of open brackets
        if (close < open) {
            backtrack(result, currentString + ")", open, close + 1, max);
        }
    }
}
