import java.util.Stack;

class Solution {
    public String simplifyPath(String path) {
        // Split the path by one or more slashes
        String[] components = path.split("/");
        Stack<String> stack = new Stack<>();

        for (String directory : components) {
            // Case 1: Empty string (from //) or single period (.) 
            // We do nothing and stay in the current directory
            if (directory.isEmpty() || directory.equals(".")) {
                continue;
            }
            
            // Case 2: Double period (..)
            // Move up one level by popping from the stack if it's not empty
            if (directory.equals("..")) {
                if (!stack.isEmpty()) {
                    stack.pop();
                }
            } 
            // Case 3: A valid directory or file name (including "...")
            else {
                stack.push(directory);
            }
        }

        // Build the final canonical path
        StringBuilder result = new StringBuilder();
        for (String dir : stack) {
            result.append("/").append(dir);
        }

        // If the stack was empty, return root "/", otherwise return the built string
        return result.length() == 0 ? "/" : result.toString();
    }
}
