class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
        // Pointer for the end of the valid elements in nums1
        int p1 = m - 1;
        // Pointer for the end of nums2
        int p2 = n - 1;
        // Pointer for the very last index of the nums1 array
        int pSorted = m + n - 1;

        // While there are elements to compare in both arrays
        while (p1 >= 0 && p2 >= 0) {
            // Compare the elements and place the larger one at the end
            if (nums1[p1] > nums2[p2]) {
                nums1[pSorted] = nums1[p1];
                p1--;
            } else {
                nums1[pSorted] = nums2[p2];
                p2--;
            }
            pSorted--;
        }

        // If there are leftover elements in nums2, copy them.
        // We don't need to worry about nums1 leftovers because they are 
        // already in their correct sorted positions.
        while (p2 >= 0) {
            nums1[pSorted] = nums2[p2];
            p2--;
            pSorted--;
        }
    }
}
