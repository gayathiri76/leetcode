import java.util.*;

class Solution {
    public List<String> fullJustify(String[] words, int maxWidth) {
        List<String> result = new ArrayList<>();
        int i = 0;

        while (i < words.length) {
            int lineLength = words[i].length();
            int last = i + 1;
            
            // Step 1: Find how many words fit in the current line
            while (last < words.length) {
                if (lineLength + 1 + words[last].length() > maxWidth) break;
                lineLength += 1 + words[last].length();
                last++;
            }

            StringBuilder sb = new StringBuilder();
            int count = last - i;
            
            // Step 2: Handle different justification cases
            if (last == words.length || count == 1) {
                // Case A: Last line or single-word line (Left Justified)
                for (int j = i; j < last; j++) {
                    sb.append(words[j]);
                    if (j < last - 1) sb.append(" ");
                }
                while (sb.length() < maxWidth) sb.append(" ");
            } else {
                // Case B: Fully justified line
                int spaces = (maxWidth - (lineLength - (count - 1)));
                int spacePerGap = spaces / (count - 1);
                int extraSpaces = spaces % (count - 1);
                
                for (int j = i; j < last; j++) {
                    sb.append(words[j]);
                    if (j < last - 1) {
                        int spacesToAdd = spacePerGap + (j - i < extraSpaces ? 1 : 0);
                        sb.append(" ".repeat(spacesToAdd));
                    }
                }
            }
            
            result.add(sb.toString());
            i = last; // Move to the next set of words
        }
        
        return result;
    }
}
