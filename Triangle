class Solution {
    public int minimumTotal(List<List<Integer>> triangle) {
        int n = triangle.size();
        // Start from the second to last row and move upwards
        for (int row = n - 2; row >= 0; row--) {
            for (int col = 0; col <= row; col++) {
                // Find the minimum of the two adjacent children in the row below
                int minChild = Math.min(triangle.get(row + 1).get(col), 
                                        triangle.get(row + 1).get(col + 1));
                
                // Update the current cell with its value + minChild
                int currentVal = triangle.get(row).get(col);
                triangle.get(row).set(col, currentVal + minChild);
            }
        }
        // The top element now contains the minimum path sum
        return triangle.get(0).get(0);
    }
}
